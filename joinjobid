local Players=game:GetService("Players")
local TeleportService=game:GetService("TeleportService")
local player=Players.LocalPlayer
local playerGui=player:WaitForChild("PlayerGui")
local screenGui=Instance.new("ScreenGui")
screenGui.Name="JobIDJoiner"
screenGui.ResetOnSpawn=false
screenGui.Parent=playerGui
local frame=Instance.new("Frame")
frame.Size=UDim2.new(0,530,0,62)
frame.AnchorPoint=Vector2.new(0.5,1)
frame.Position=UDim2.new(0.5,0,1,-60)
frame.BackgroundColor3=Color3.fromRGB(255,220,0)
frame.BackgroundTransparency=0.3
frame.BorderSizePixel=0
frame.Parent=screenGui
local textBox=Instance.new("TextBox")
textBox.Size=UDim2.new(1,-110,1,0)
textBox.Position=UDim2.new(0,10,0,0)
textBox.BackgroundTransparency=1
textBox.Text=""
textBox.TextSize=18
textBox.TextColor3=Color3.fromRGB(0,0,0)
textBox.TextXAlignment=Enum.TextXAlignment.Left
textBox.ClearTextOnFocus=false
textBox.Font=Enum.Font.SourceSans
textBox.Parent=frame
local placeholder=Instance.new("TextLabel")
placeholder.Size=textBox.Size
placeholder.Position=textBox.Position
placeholder.BackgroundTransparency=1
placeholder.Text="Type JobID"
placeholder.TextColor3=Color3.fromRGB(90,90,90)
placeholder.TextSize=18
placeholder.Font=Enum.Font.SourceSans
placeholder.TextXAlignment=Enum.TextXAlignment.Left
placeholder.Parent=frame
local joinButton=Instance.new("TextButton")
joinButton.Size=UDim2.new(0,100,1,0)
joinButton.Position=UDim2.new(1,-100,0,0)
joinButton.BackgroundColor3=Color3.fromRGB(0,170,0)
joinButton.TextColor3=Color3.fromRGB(255,255,255)
joinButton.Text="Join"
joinButton.TextSize=18
joinButton.Font=Enum.Font.SourceSansBold
joinButton.Visible=false
joinButton.Parent=frame
textBox.Focused:Connect(function()
	placeholder.Visible=false
end)
textBox:GetPropertyChangedSignal("Text"):Connect(function()
	local hasText=textBox.Text:gsub("%s+","")~=""
	placeholder.Visible=not hasText
	joinButton.Visible=hasText
end)
joinButton.MouseButton1Click:Connect(function()
	local jobId=textBox.Text:match("^%s*(.-)%s*$")
	if jobId~="" then
		pcall(function()
			TeleportService:TeleportToPlaceInstance(game.PlaceId,jobId,player)
		end)
	end
end)
