local RunService=game:GetService("RunService")
local Players=game:GetService("Players")
local Stats=game:GetService("Stats")
local player=Players.LocalPlayer
local playerGui=player:WaitForChild("PlayerGui")
local screenGui=Instance.new("ScreenGui")
screenGui.Name="PerformanceCounter"
screenGui.ResetOnSpawn=false
screenGui.Parent=playerGui
local frame=Instance.new("Frame")
frame.Size=UDim2.new(0,190,0,108)
frame.Position=UDim2.new(0,0,0,250)
frame.BackgroundColor3=Color3.fromRGB(0,0,0)
frame.BorderSizePixel=0
frame.Parent=screenGui
local divider=Instance.new("Frame")
divider.Size=UDim2.new(0,1,1,-10)
divider.Position=UDim2.new(0.5,0,0,5)
divider.BackgroundColor3=Color3.fromRGB(255,255,255)
divider.BorderSizePixel=0
divider.Parent=frame
local fpsTitle=Instance.new("TextLabel")
fpsTitle.Size=UDim2.new(0.5,0,0,20)
fpsTitle.Position=UDim2.new(0,0,0,0)
fpsTitle.BackgroundTransparency=1
fpsTitle.Text="FPS"
fpsTitle.TextColor3=Color3.fromRGB(255,255,255)
fpsTitle.TextSize=14
fpsTitle.Font=Enum.Font.SourceSansBold
fpsTitle.Parent=frame
local fpsValue=Instance.new("TextLabel")
fpsValue.Size=UDim2.new(0.5,0,1,-20)
fpsValue.Position=UDim2.new(0,0,0,20)
fpsValue.BackgroundTransparency=1
fpsValue.Text="0"
fpsValue.TextColor3=Color3.fromRGB(255,255,255)
fpsValue.TextScaled=true
fpsValue.Font=Enum.Font.SourceSansBold
fpsValue.Parent=frame
local pingTitle=Instance.new("TextLabel")
pingTitle.Size=UDim2.new(0.5,0,0,20)
pingTitle.Position=UDim2.new(0.5,0,0,0)
pingTitle.BackgroundTransparency=1
pingTitle.Text="PING"
pingTitle.TextColor3=Color3.fromRGB(255,255,255)
pingTitle.TextSize=14
pingTitle.Font=Enum.Font.SourceSansBold
pingTitle.Parent=frame
local pingValue=Instance.new("TextLabel")
pingValue.Size=UDim2.new(0.5,0,1,-20)
pingValue.Position=UDim2.new(0.5,0,0,20)
pingValue.BackgroundTransparency=1
pingValue.Text="0"
pingValue.TextColor3=Color3.fromRGB(255,255,255)
pingValue.TextScaled=true
pingValue.Font=Enum.Font.SourceSansBold
pingValue.Parent=frame
local frames=0
local lastUpdate=tick()
RunService.RenderStepped:Connect(function()
	frames+=1
	local now=tick()
	if now-lastUpdate>=1 then
		fpsValue.Text=tostring(frames)
		local ok,ping=pcall(function()
			return Stats.Network.ServerStatsItem["Data Ping"]:GetValue()
		end)
		if ok then
			pingValue.Text=tostring(math.floor(ping+0.5))
		end
		frames=0
		lastUpdate=now
	end
end)
print("Skidded by pungtoi")
